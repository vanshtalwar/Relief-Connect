generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  passwordHash    String?
  role            String   @default("VICTIM")
  phone           String?
  image           String?
  isVerified      Boolean  @default(false)
  backgroundCheck Boolean  @default(false)
  locationConsent Boolean  @default(false)
  skills          Json?
  inventory       Json?
  latitude        Float?
  longitude       Float?
  createdAt       DateTime @default(now())

  requests        HelpRequest[] @relation("Requester")
  claimedRequests HelpRequest[] @relation("Volunteer")
  messages        ChatMessage[]
  reviewsGiven    Review[]      @relation("Reviewer")
  reviewsReceived Review[]      @relation("Reviewee")
}

model HelpRequest {
  id          String                    @id @default(uuid())
  title       String
  description String
  category    String
  urgency     String
  status      String                    @default("OPEN")
  latitude    Float
  longitude   Float
  photoUrl    String?
  clientUuid  String                    @unique
  requesterId String
  volunteerId String?
  isSOS       Boolean                   @default(false)
  locationName String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  // location    Unsupported("geography")?

  requester          User          @relation("Requester", fields: [requesterId], references: [id])
  assignedVolunteers User?         @relation("Volunteer", fields: [volunteerId], references: [id])
  statusHistory      StatusEvent[]
  messages           ChatMessage[]
  reviews            Review[]

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([updatedAt])
  // @@index([location], map: "idx_helprequest_location", type: Gist)
}

model StatusEvent {
  id        String   @id @default(uuid())
  requestId String
  status    String
  changedAt DateTime @default(now())
  note      String?

  request   HelpRequest @relation(fields: [requestId], references: [id])
}

model Alert {
  id        String   @id @default(uuid())
  message   String
  latitude  Float
  longitude Float
  radiusKm  Float
  createdBy String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  keys      Json
  userId    String?
  createdAt DateTime @default(now())
}

